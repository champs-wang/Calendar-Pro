{
	"name": "diary-obsidian",
	"version": "1.3.6",
	"description": "This is a diary obsidian plugin for Obsidian (https://obsidian.md)",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "echo \"No tests configured\""
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@eslint/json": "0.14.0",
		"@types/node": "20.12.12",
		"@typescript-eslint/parser": "8.35.1",
		"esbuild": "0.28.1",
		"eslint": "9.39.4",
		"eslint-plugin-obsidianmd": "0.3.0",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"obsidian": "1.8.7",
		"tslib": "2.4.0",
		"typescript": "5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.2",
		"date-chinese": "^2.1.4",
		"date-holidays": "^3.30.2",
		"korean-lunar-calendar": "0.3.6"
	},
	"pnpm": {
		"overrides": {
			"ajv@6": "6.15.0",
			"ajv@8": "8.20.0",
			"brace-expansion@1": "1.1.15",
			"brace-expansion@2": "2.1.1",
			"fast-uri": "3.1.2",
			"flatted": "3.4.2",
			"js-yaml": "4.2.0",
			"minimatch@3": "3.1.5",
			"minimatch@8": "8.0.7",
			"minimatch@9": "9.0.9",
			"picomatch@2": "2.3.2",
			"yaml": "2.9.0"
		}
	}
}
